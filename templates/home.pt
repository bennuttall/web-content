<div metal:use-macro="layout">
  <div metal:fill-slot="head" tal:omit-tag="1">
    <meta name="description" content="The homepage of software engineer Ben Nuttall" />
    <meta property="og:url" content="${site.config.base_url}/" />
    <meta property="og:title" content="${page.title}" />
    <meta property="og:description" content="The homepage of software engineer Ben Nuttall" />
    <meta name="twitter:title" content="${page.title}" />
    <meta name="twitter:description" content="The homepage of software engineer Ben Nuttall" />
  </div>

  <div metal:fill-slot="title" tal:omit-tag="1">software engineer</div>

  <section metal:fill-slot="content">
    <div>
      <div class="row">
        <div class="small-12 columns">
          <h1>${page.title}</h1>
        </div>
      </div>
      <div class="row">
        <div class="small-12 medium-8 columns entry-content">
          <div tal:content="structure page.html"></div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="small-12 medium-8 columns">
        <h2>Latest blog posts</h2>
      </div>
      <div class="small-12 medium-8 columns" tal:repeat="post site.posts[:5]">
        <time datetime="${post.published.isoformat(timespec='seconds')}" title="${post.published.isoformat(timespec='seconds')}">${post.published.strftime("%-d %B %Y")}</time>
        <h2><a href="/${post.link}" tal:content="structure post.title"></a></h2>
        <p tal:content="structure post.excerpt"></p>
        <div class="callout primary tags">
          Tags: <a tal:repeat="tag post.tags" href="/blog/tags/${tag}">${tag.replace("-", " ")}</a>
        </div>
      </div>
      <div class="small-12 medium-8 columns">&nbsp;</div>
    </div>
  </section>
</div>