<div metal:use-macro="layout">
  <div metal:fill-slot="head" tal:omit-tag="1">
    <meta name="description" content="Ben Nuttall blog - ${title}" />
    <meta property="og:url" content="${site.config.base_url}/${link}" />
    <meta property="og:title" content="Ben Nuttall blog - ${title}" />
    <meta property="og:description" content="Ben Nuttall blog - ${title}" />
    <meta name="twitter:title" content="Ben Nuttall blog - ${title}" />
    <meta name="twitter:description" content="Ben Nuttall blog - ${title}" />
  </div>

  <div metal:fill-slot="title" tal:omit-tag="1">${title}</div>

  <section metal:fill-slot="content">
    <div class="row">
      <div class="small-12 medium-8 columns">
        <h1>${title}</h1>
        <div tal:repeat="post posts">
          <time datetime="${post.published.isoformat(timespec='seconds')}" title="${post.published.isoformat(timespec='seconds')}">${post.published.strftime("%-d %B %Y")}</time>
          <h2><a href="/${post.link}" tal:content="structure post.title"></a></h2>
          <p tal:content="structure post.excerpt"></p>
          <div class="callout primary tags">
            Tags: <a tal:repeat="tag post.tags" href="/blog/tags/${tag}">${tag.replace("-", " ")}</a>
          </div>
        </div>
      </div>
      <div class="small-12 medium-4 columns">
        <h3>Archive</h3>
        <ul>
          <li><a href="/blog/archive/">All</a></li>
          <li tal:repeat="year site.archive.keys()">
            <a href="/blog/${year}/">${year}</a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</div>
