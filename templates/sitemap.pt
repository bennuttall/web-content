<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>${site.config.base_url}</loc>
  </url>
  <url>
    <loc>${site.config.base_url}/blog</loc>
  </url>
  <url>
    <loc>${site.config.base_url}/blog/archive</loc>
  </url>
  <url>
    <loc>${site.config.base_url}/blog/tags</loc>
  </url>
  <tal:block tal:repeat="page site.pages">
  <url tal:condition="page.slug != '404'">
    <loc>${site.config.base_url}/${page.link}</loc>
  </url>
  </tal:block>
  <url tal:repeat="post site.posts">
    <loc>${site.config.base_url}/${post.link}</loc>
    <lastmod>${post.modified.isoformat(timespec="seconds")}</lastmod>
  </url>
  <url tal:repeat="tag site.tags">
    <loc>${site.config.base_url}/blog/tags/${tag}/</loc>
  </url>
  <url tal:repeat="year years">
    <loc>${site.config.base_url}/blog/${year}/</loc>
  </url>
  <url tal:repeat="(year, month) months">
    <loc>${site.config.base_url}/blog/${year}/${month}/</loc>
  </url>
</urlset>