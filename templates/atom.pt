<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Ben Nuttall's blog</title>
  <link href="${site.config.base_url}/blog/" />
  <link href="${site.config.base_url}/blog/atom.xml" rel="self" />
  <id>${site.config.base_url}/blog/</id>
  <author>
    <name>Ben Nuttall</name>
  </author>
  <updated>${site.now.isoformat(timespec="seconds")}</updated>

  <entry tal:repeat="post site.posts[:10]">
    <title><![CDATA[${structure:post.title}]]></title>
    <link href="${site.config.base_url}/${post.link}/" />
    <id>${site.config.base_url}/${post.link}</id>
    <published>${post.published.isoformat(timespec="seconds")}</published>
    <updated>${post.modified.isoformat(timespec="seconds")}</updated>
    <category tal:repeat="tag post.tags" term="${tag}" />
    <summary><![CDATA[${structure:post.excerpt}]]></summary>
    <content type="html"><![CDATA[${structure:post.html_atom_safe}]]></content>
  </entry>
</feed>